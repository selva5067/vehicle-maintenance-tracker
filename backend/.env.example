PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/vehicle_maintenance_tracker
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Email (used for reminder notifications) - example uses Gmail SMTP with an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Vehicle Maintenance Tracker <your_email@gmail.com>"

# How many days before a due date to send a reminder
REMINDER_DAYS_BEFORE=3
